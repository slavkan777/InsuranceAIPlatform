# InsuranceAIPlatform local environment example
# Copy to .env.local for local development.

# mock    = deterministic frontend-only local mode, no credentials, default
# backend = use the local .NET API contract at VITE_INSURANCE_API_BASE_URL
VITE_INSURANCE_API_MODE=mock
VITE_INSURANCE_API_BASE_URL=http://localhost:5284

# Optional backend-side values if a local backend implementation is used.
# Do not commit real secrets.
# LLM_PROVIDER=mock
# OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# VECTOR_BACKEND=in-memory
# QDRANT_URL=http://localhost:6333
